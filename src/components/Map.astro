---
import { Image } from "astro:assets";

import PDF from "../assets/pdf.svg";
import SVG from "../assets/svg.svg";
import Commons from "../assets/commons.svg";

const { src, alt, title, details, updated, pdf, svg, commons } = Astro.props;
---
<figure class="vi-mapitem">
    <Image src={src} alt={alt} height="320" densities={[1.5, 2]}/>
    <figcaption>
        <div class="title">{title}</div>
        <div class="details">{details}</div>
        <div class="updated">Updated on {updated}</div>
        <div class="links">
            {pdf && <a href={pdf} class="vi-button" title="Download PDF"><PDF /> Download</a>}
            {svg && <a href={svg} class="vi-button" title="Download SVG"><SVG /> Download</a>}
            {commons && <a href={commons} class="vi-button" title="View it on Wikimedia Commons"><Commons /> View</a>}
        </div>
    </figcaption>
</figure>

<style>
.vi-mapitem {
	background-color: hsl(var(--vi-accent-color--hsl)/5%);
	padding: 0.5rem;
	border-radius: 1rem;
	margin: 1rem 0;
	border: solid transparent 1px;
    display: grid;
    gap: 1rem;
}

@media only screen and (min-width: 425px) {
    .vi-mapitem {
        grid-template-columns: 150px 1fr;
    }
}

@media only screen and (max-width: 425px) {
    .vi-mapitem img {
        aspect-ratio: 3/2;
    }
}

@media (prefers-color-scheme: dark) {
    .vi-mapitem img {
        filter: brightness(.8);
    }
}

.vi-mapitem img {
    margin: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.vi-mapitem figcaption {
    gap: 0.25em;
    display: flex;
    flex-direction: column;
}

.title {
	font-family: var(--vi-display-font);
	font-weight: 600;
	font-size: 1.25em;
    line-height: 1.25;
}

.details {
    line-height: 1.45;
}

.updated {
	font-size: 0.8em;
	opacity: 0.8;
	font-style: italic;
	display: inline-block;
}

.links {
    display: flex;
    gap: 1ch;
    flex-wrap: wrap;
    grid-area: span 1 / span 2;
    margin-top: auto;
    padding-top: 0.5em;
}

.vi-button {
    font-size: .85rem;
    margin: 0;
}

.vi-button svg {
    width: 1.5em;
    height: 1.5em;
    vertical-align: -.4em;
}
</style>