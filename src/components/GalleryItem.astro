---
const {src, alt, info, details} = Astro.props
import { Image } from "astro:assets";
---
<a href={src.src} class="vi-gallery__item">
	<figure>
		<Image src={src} alt={alt} height="250" densities={[1.5, 2]} />
		<figcaption><div><div>{info}</div>{details}</div></figcaption>
	</figure>
</a>

<style>
.vi-gallery__item {
	flex: 1 0 auto;
	text-decoration: none;
	display: block;
}

.vi-gallery__item figure {
	position: relative;
	overflow: hidden;
	border-radius: 0.5rem;
}

.vi-gallery__item img {
	margin: 0;
	height: 225px;
	width: 225px;
	object-fit: cover;
	object-position: center;
}

.vi-gallery__item figcaption {
	color: var(--vi-body-color--secondary);
	position: absolute;
	bottom: -50%;
	left: 0;
	width: 225px;
	height: 450px;
	background: radial-gradient(at top right, hsl(var(--vi-body-background-color--hsl)/0), hsl(var(--vi-body-background-color--hsl)/50%) 60%, var(--vi-body-background-color));
	opacity: 0;
	display: grid;
	place-items: end start;

	transition: bottom .2s, height .2s, opacity .2s;

	font-size: 0.8em;
	line-height: 1.25;
}

.vi-gallery__item figcaption > div {
	padding: 1em;
}

.vi-gallery__item figcaption div div {
	font-family: var(--vi-display-font);
	font-weight: 800;
	font-size: 1.15rem;
	color: var(--vi-body-color--secondary)
}

.vi-gallery__item:hover figcaption {
	opacity: 1;
	height: 225px;
	bottom: 0;
}
</style>