---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import GalleryImage from "../components/GalleryImage.astro";

import EdF1 from "../images/gallery/IMG_20240925_190332.jpg";
import EdF2 from "../images/gallery/IMG_20240925_190837.jpg";
import Glories from "../images/gallery/IMG_20241005_192345.jpg";
import Granota from "../images/gallery/IMG_20241006_093848.jpg";
import Planes from "../images/gallery/IMG_20241006_094206.jpg";
import Xemeneia1 from "../images/gallery/IMG_20241007_181957.jpg";
import Xemeneia2 from "../images/gallery/IMG_20241008_180826.jpg";
import Xemeneia3 from "../images/gallery/IMG_20241008_181451.jpg";
import Xemeneia4 from "../images/gallery/IMG_20241008_183017.jpg";
import Xemeneia5 from "../images/gallery/IMG_20241008_183908.jpg";
import S4000 from "../images/gallery/IMG_20241016_201707.jpg";
import Parlament from "../images/gallery/IMG_20241026_143136.jpg";
import Sicilia from "../images/gallery/IMG_20241108_172612.jpg";
import Sunset1 from "../images/gallery/IMG_20241121_173217.jpg";
import Sunset2 from "../images/gallery/IMG_20241121_173616.jpg";
import Sunset3 from "../images/gallery/IMG_20241121_175137.jpg";
import CargoTrain from "../images/gallery/IMG_20241203_164620.jpg";
import Velaro from "../images/gallery/IMG_20241203_171406.jpg";
---

<Layout
	title="gallery - astrid"
	description="A collection of good pictures"
	>
	<header>
		<h1>Gallery</h1>
		<p>This is a collection of good, cool or interesting pictures I've taken. Probably not the best pictures ever, but worth showing nonetheless.</p>
		<p>View more on my <a href="https://www.flickr.com/photos/its_astrid" target="_blank" rel="noreferrer">Flickr page</a>.</p>
	</header>
	<div class="vi-gallery-layout">
		<GalleryImage src={EdF1} alt="An empty 449 medium distance train entering the Estació de França, about to make the Barcelona-Reus service." title="449 at EdF" details="Canon 550D, ISO400, 1/500, f/5.6" licence="CC BY-SA 4.0" flickr="https://www.flickr.com/photos/its_astrid/54025778705" />
		<GalleryImage src={EdF2} alt="The interior of the Estació de França. On the tracks, there are various trains stationed: a medium distance 449 train, two Rodalies 447 trains, as well as one double-decker Rodalies 450 train. The roof on top is covered with a blue net." title="Interior EdF" details="Canon 550D, ISO3200, 1/250, f/5.6" licence="CC BY-SA 4.0" flickr="https://www.flickr.com/photos/its_astrid/54025778750"/>
		<GalleryImage src={Glories} alt="Two tramways crossing next to the Encants market, with the Glòries tower and the Disseny Hub behind." title="Tramway at Glories" details="Canon 550D, ISO400, 1/80, f/4.5" licence="CC BY-SA 4.0" flickr="https://www.flickr.com/photos/its_astrid/54057485545" />
		<GalleryImage src={Granota} alt="A FCC class 400 &#x0022;frog&#x0022; train arriving at les Planes station, from the FGC depot in Rubí, in the middle of the vegetation of the Collserola park. It's a three-car set with white-and-green carriages which, combined with the round front lights, make it resemble a frog." title="Granota at les Planes" details="Canon 550D, ISO400, 1/400, f/5.0" licence="CC BY-SA 4.0" flickr="https://www.flickr.com/photos/its_astrid/54057356589" />
		<GalleryImage src={Planes} alt="An FGC class 112 train leaving Les Planes station, heading towards Terrassa. There's an FCC class 400 &quot;frog&quot; on the background." title="112 at les Planes" details="Canon 550D, ISO400, 1/400, f/5.0" licence="CC BY-SA 4.0" flickr="https://www.flickr.com/photos/its_astrid/54057485690"/>
		<GalleryImage src={Xemeneia1} alt="The &quot;three chimneys&quot; of Sant Adrià del Besòs. This used to be a thermal power plant that was operated by Endesa until 2011, when it was decommissioned. It consists of three identical chimneys side by side, with a height of 200 m, and a separate horizontal building which housed the turbines until they were dismantled. The power plant is located next to a beach and, while in operation, it polluted the surrounding environment and the water. There's some graffiti on the exterior walls of the complex." title="Three Chimneys" details="Canon 550D, ISO100, 1/400, f/4.5" licence="CC BY-NC-SA 4.0" />
		<GalleryImage src={Xemeneia2} alt="What looks like the inside of an abandoned building, where numerous concrete columns supporting the concrete structure can be seen. There's a hole on the floor between two of the columns, with a metar guardrail around it. At the end, a set of metal stairs is visible. The space is unlit, lending it an apocalyptic atmosphere." title="Abandoned complex" details="Canon 550D, ISO800, 1/13, f/4.5" licence="CC BY-NC-SA 4.0" />
		<GalleryImage src={Xemeneia3} alt="&quot;Prehension&quot; is an art piece by Asad Raza. It features long, white fabric strips hanging off the ceiling that move in the wind, &quot;giv[ing] form to the wind&quot;. Behind, there's another piece by Claire Fontaine, consisting of luminous letters that read &quot;When women strike the world stops&quot;. The artist wants to defend and reclaim the women's role in history. These two pieces are exhibited on the top floor of the former turbine hall, a large and tall area that also features a giant crane on top. " title="Prehension" details="Canon 550D, ISO200, 1/80, f/4.5" licence="CC BY-NC-SA 4.0" />
		<GalleryImage src={Xemeneia4} alt="Kuluanji Kia Henda's &quot;The Frankenstein Tree&quot; consists of tree branches that have been joined together with wood slabs and screws, so that it resembles a forest with Frankenstein-ed trees. The work meditates on the extraordinary power of nature to heal itself, even after catastrophic climate events and war." title="Frankenstein trees" details="Canon 550D, ISO400, 1/30, f/4.5" licence="CC BY-NC-SA 4.0" />
		<GalleryImage src={Xemeneia5} alt="&quot;Un Intruso (uninvited, into chaos)&quot;, by Mike Nelson, is a small hut next to the power plant. Built with the remains of the demolished buildings nearby, it seems as if it has always been here, as if it wasn't just an art piece. The visitor is invited to enter and take a look to the chimneys: a megalithic statement of power, not only from the perspective of energy, but also on political, economic, environmental and, above all, human levels; making the observer reflect about their future." title="Uninvited guest" details="Canon 550D, ISO100, 1/500, f/4.5" licence="CC BY-NC-SA 4.0" />
		<GalleryImage src={S4000} alt="A white train with a red front entering and about to stop at Espanya station. There's a screen above the driver's compartment that says 124. The picture is a bit blurry." title="Last S4000" details="Canon 550D, ISO1600, 1/13, f/11" licence="CC BY-SA 4.0" flickr="https://www.flickr.com/photos/its_astrid/54095602973" />
		<GalleryImage src={Parlament} alt="Inside the parliament of Catalonia. It's a surprisingly small room with a narrow central corridor covered with a red carpet and red cushioned seats on both sides of it. Behind the seats, there's a place for visitors and media to sit. At the end of the room, there's a metal clock hanging on the wall. The place is ornamented with ionic style columns and rounded arches. The ceiling, made of wood, has a big ball-like chandelier hanging on." title="Parliament of Catalonia" details="Canon 550D, ISO400, 1/60, f/3.5" licence="CC BY-NC-SA 4.0" />
		<GalleryImage src={Sicilia} alt="A tram about to leave Sicília stop, heading towards the north of the city. The Glòries tower, a rounded glass skyscraper that looks like a cucumber, is in the background." title="New tramway branch" details="Canon 550D, ISO100, 1/320, f/5.6" licence="CC BY-SA 4.0" flickr="https://www.flickr.com/photos/its_astrid/54125983441" />
		<GalleryImage src={Sunset1} alt="A view of the Mercat Nou metro station, in the lower left corner, alongside the commuter train tracks, under the sunset. A train is leaving the city at the same time as a metro is entering the station, under the sunset." title="Train sunset" details="Canon 550D, ISO100, 1/300, f/5.3" licence="CC BY-NC-SA 4.0" />
		<GalleryImage src={Sunset2} alt="Two trains meeting, while going in opposite directions, at the commuter train tracks that lead to the outskirts of the city. The sky is tinted pink and purple as the sun sets." title="Meeting under the sunset" details="Canon 550D, ISO100, 1/300, f/5.3" licence="CC BY-NC-SA 4.0" />
		<GalleryImage src={Sunset3} alt="A train speeding beneath a metal pedestrian bridge, under the sunset. The sky has a yellow tone, which fades to purple on top of the photo. The train pictured is a Renfe 447 commuter train, with some graffiti on its side." title="Speeding under the sunset" details="Canon 550D, ISO100, 1/300, f/5.3" licence="CC BY-NC-SA 4.0" />
		<GalleryImage src={CargoTrain} alt="A Renfe cargo train goes by an empty field under the purple sky." title="Afternoon cargo" details="Canon 550D, ISO200, 1/500, f/5.6" licence="CC BY-SA 4.0" />
		<GalleryImage src={Velaro} alt="A Velaro E train operated by Renfe speeds up as it exits the city, on top of a bridge in the middle of the forest." title="Velaro in the wild" details="Canon 550D, ISO800, 1/60, f/5.6" licence="CC BY-SA 4.0" />
		<!-- <GalleryImage src={Velaro} alt="Some alt text" title="Test" details="Canon 550D, ISO100, 1/300, f/5.3" licence="CC BY-SA 4.0" flickr="" /> -->
	</div>
	<Footer />
</Layout>

<style>

header {
	max-width: 600px;
	margin: auto;
	padding: 2rem 1rem;
}

.vi-gallery-layout {
	display: flex;
	flex-wrap: wrap;
	justify-content: center;
	gap: 1rem;
	padding: 0 2rem 2rem;
	max-width: 1100px;
	margin: 0 auto;
}
</style>