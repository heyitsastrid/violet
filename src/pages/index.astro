---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="astrid's website - home"
	description="Just a silly girl"
	image=""
	>
	<div class="vi-main-wrapper">
		<div class="vi-welcome">
			<div class="vi-welcome-text">
				<h1>
					Hi! 
					<div>
						I'm <span>astrid</span>
					</div>
				</h1>
				<a href="#main" class="vi-welcome__more-info">
					Scroll down
				</a>
				<div class="vi-welcome__slider"><span></span><span></span></div> 			
			</div>
		</div>
		<main id="main">
			<section class="vi-mp-box">
				<h2>Who?</h2>
				<p>I'm astrid, a random transfem living in Catalunya right now. </p>
			</section>
			<section class="vi-mp-box"></section>
			<section class="vi-mp-box"></section>
		</main>
	</div>
	<div class="footer">
		bonjour uwu
		<p>bondjour nya</p>
	</div>
</Layout>

<style>
	:global(.vi-navbar.vi-navbar) {
		position: fixed;
	}

	.vi-main-wrapper {
		background-image: radial-gradient(at left top, hsl(300 7% 14%/0%), hsl(300 7% 14%/20%) 50%, hsl(300 7% 14%/100%) 95%), url(../assets/sunset.jpg);
		background-position: center, center bottom;
		background-attachment: fixed, fixed;
		background-size: cover, cover;
		background-repeat: no-repeat, no-repeat;

		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2em;
		align-items: stretch;

		padding: 2em;
	}

	.vi-welcome {
		height: 100%
	}

	.vi-welcome-text {
		height: calc(100dvh - 4em);
		position: sticky;
		top: 2em;
		left: 0;
	}

	.box {
		height: 100vh;
		background-color: blue;
		margin: 1rem 0;
	}

	main {
		margin-top: 100vh;
	}

	.vi-welcome-text {
		/* padding: 0 3rem 3rem; */
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 1rem 1.5rem;
		justify-items: start;
		align-content: end;
	}

	.vi-welcome-text h1 {
		color: hsl(345 14% 89%);
		font-size: clamp(1.75rem, 5vmin, 3rem);
		margin: 0;
		white-space: nowrap;
		font-weight: 800;
		line-height: 1;
	}

	.vi-welcome-text h1 div {
		font-size: clamp(3rem, 10vmin, 10rem);
	}

	.vi-welcome-text h1 div span {
		color: transparent;
		background-image: linear-gradient(45deg, hsl(346 15% 66%), hsl(15 62% 71%), hsl(346 15% 66%), hsl(15 62% 71%));
		background-clip: text;
		animation: gradient 5s infinite;
		background-size: 400%;
	}

	@keyframes gradient {
		0% {
			background-position: 0% 100%
		}

		100% {
			background-position: 100% 0%
		}
	}

	@media only screen and (max-width: 700px) {
		.aroma-header__text {
			padding: 0 1rem 3rem;
			gap: 1rem;
		}
	}

	.vi-welcome__more-info {
		color: var(--vi-body-color--secondary);
		text-transform: uppercase;
		letter-spacing: 1px;
		line-height: 1;
	}

	.vi-welcome__more-info:hover {
		text-decoration: none;
	}

	.vi-welcome__slider {
		display: flex;
		flex-direction: column;
		gap: 5px;
		grid-area: 1/1/3/2;
	}

	.vi-welcome__slider span {
		width: 3px;
		background-color: hsl(var(--vi-accent-color--hsl)/50%);
		flex-shrink: 0;
		transition: flex-grow .3s;
		border-radius: 3px
	}

	.vi-welcome__slider span:last-of-type {
		flex-grow: 1;
		flex-basis: 10px;
	}

	.vi-welcome__slider span:first-of-type {
		flex-grow: 0;
	}

	.vi-welcome__more-info:hover ~ .vi-welcome__slider span {
		transition: flex-grow .5s;
	}

	.vi-welcome__more-info:hover ~ .vi-welcome__slider span:last-of-type {
		flex-grow: 0;
	}

	.vi-welcome__more-info:hover ~ .vi-welcome__slider span:first-of-type {
		flex-grow: 1;
	}

</style>