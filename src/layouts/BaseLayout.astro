---
import Layout from "./Layout.astro";
const {title, description, image} = Astro.props;
import Footer from '../components/Footer.astro';
---
<Layout 
	title={title}
	description={description}
	image={image}
>
	<main id="main">
		<slot />
	</main>
	<Footer />
</Layout>

<style>
main {
	max-width: 600px;
	margin: auto;
	padding: 2rem 1rem;
}
</style>